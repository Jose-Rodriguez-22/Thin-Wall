      7897      7898      7899
CMBLOCK,START1,Node,      1
(8i10)
      4890
/PREP7
ALLSEL,ALL

INX = 1
LSTP=200					! NUMBER OF LOAD STEPS CONSIDERED
VEL = 1					! VELOCITY OF LASER
SEG = LSTP+1				! NUMBER OF SEGMENTS
R1= 1
LD= 50000.0
TM_L = 200					! END TIME OF THE MOVING HEAT SOURCE
TM_S = 0					! START TIME OF THE MOVING HEAT SOURCE
FP = 'Yes'					! FIRST PATCH POINTER

!! ======STORE EACH WELD DATA AS A PART OF AN ARRAY AND WRITE TO A FILE===========
! ======INDEX
*IF,FP,EQ,'Yes',THEN
*CFOPEN,INDEX1,TXT,,
*VWRITE,INX
%I
*CFCLOSE

! ======VELOCITY
*CFOPEN,VELOCITY1,TXT,,
*VWRITE,VEL
(F10.5)
*CFCLOSE

! ======LSTP
*CFOPEN,LSTP1,TXT,,
*VWRITE,LSTP
%I
*CFCLOSE

! ======R1
*CFOPEN,CON1,TXT,,
*VWRITE,R1
(F10.5)
*CFCLOSE

! ======LD
*CFOPEN,LD1,TXT,,
*VWRITE,LD
(F30.3)
*CFCLOSE

! ======START TIME
*CFOPEN,TMST1,TXT,,
*VWRITE,TM_S
(F10.5)
*CFCLOSE

! ======END TIME
*CFOPEN,TMLT1,TXT,,
*VWRITE,TM_L
(F10.5)
*CFCLOSE

*ELSEIF,FP,EQ,'No',THEN
*CFOPEN,INDEX1,TXT,,APPEND
*VWRITE,INX
%I
*CFCLOSE

! ======VELOCITY
*CFOPEN,VELOCITY1,TXT,,APPEND
*VWRITE,VEL
(F10.5)
*CFCLOSE

! ======LSTP
*CFOPEN,LSTP1,TXT,,APPEND
*VWRITE,LSTP
%I
*CFCLOSE

! ======R1
*CFOPEN,CON1,TXT,,APPEND
*VWRITE,R1
(F10.5)
*CFCLOSE

! ======LD
*CFOPEN,LD1,TXT,,APPEND
*VWRITE,LD
(F30.3)
*CFCLOSE

! ======START TIME
*CFOPEN,TMST1,TXT,,APPEND
*VWRITE,TM_S
(F10.5)
*CFCLOSE

! ======END TIME
*CFOPEN,TMLT1,TXT,,APPEND
*VWRITE,TM_L
(F10.5)
*CFCLOSE
*ELSE
*ENDIF


!===============READ IN ALL MOVING FLUX INFO================
/INQUIRE,NLINE,LINES,INDEX1,TXT		! NUMBER OF MOVING HEAT FLUX DEFINED 

*DIM,INDEX,ARRAY,NLINE,1
*DIM,VELOCITY,ARRAY,NLINE,1
*DIM,LSTP,ARRAY,NLINE,1
*DIM,R1,ARRAY,NLINE,1
*DIM,LD,ARRAY,NLINE,1
*DIM,TMST,ARRAY,NLINE,1
*DIM,TMLT,ARRAY,NLINE,1

*VREAD,INDEX(1),'INDEX1','TXT',' ',IJK,NLINE,1,1, , 
(f3.0)
*VREAD,VELOCITY(1),'VELOCITY1','TXT',' ',IJK,NLINE,1,1, , 
(f10.5)
*VREAD,LSTP(1),'LSTP1','TXT',' ',IJK,NLINE,1,1, , 
(f3.0)
*VREAD,R1(1),'CON1','TXT',' ',IJK,NLINE,1,1, , 
(f10.5)
*VREAD,LD(1),'LD1','TXT',' ',IJK,NLINE,1,1, , 
(f30.3)
*VREAD,TMST(1),'TMST1','TXT',' ',IJK,NLINE,1,1, , 
(f10.5)
*VREAD,TMLT(1),'TMLT1','TXT',' ',IJK,NLINE,1,1, , 
(f10.5)

!==============================================================
! CREATE NODAL COMPONENT INCLUDING ALL THE "FACE"
!==============================================================
*DO,INC1,1,NLINE
	*IF,INC1,EQ,1,THEN
		CMSEL,S,'FACE%INDEX(INC1,1)%',NODE
	*ELSE
		CMSEL,A,'FACE%INDEX(INC1,1)%',NODE
	*ENDIF
*ENDDO				!INC1

CM,FACE,NODE
ALLSEL,ALL

!==============================================================
!=======CREATE LOAD RELATED VARIABLE FOR EACH PATH=============
!==============================================================
*DO,INC1,1,NLINE									! LOOP OVER EACH MOVING FLUX LOAD

	CMSEL,S,'PATH%INDEX(INC1,1)%',NODE				! SELECT THE NODES OF PATH%INDEX%
		
	*GET,'PT_ND%INDEX(INC1,1)%',NODE,,COUNT			! TOTAL NUMBER OF NODES ON THE PATH%INDEX%
	
	*DIM,'N_PT%INDEX(INC1,1)%',ARRAY,PT_ND%INDEX(INC1,1)%,1					!ARRAY TO NODE NUMBER OF THE LASER PATH%INDEX%
	*DIM,'X_PT%INDEX(INC1,1)%',ARRAY,PT_ND%INDEX(INC1,1)%,1					!ARRAY TO STORE X LOCATION OF THE LASER PATH%INDEX%
	*DIM,'Y_PT%INDEX(INC1,1)%',ARRAY,PT_ND%INDEX(INC1,1)%,1					!ARRAY TO STORE Y LOCATION OF THE LASER PATH%INDEX%
	*DIM,'Z_PT%INDEX(INC1,1)%',ARRAY,PT_ND%INDEX(INC1,1)%,1					!ARRAY TO STORE Z LOCATION OF THE LASER PATH%INDEX%
	
	*DIM,'PT_LEN%INDEX(INC1,1)%',ARRAY,PT_ND%INDEX(INC1,1)%,1				!ARRAY TO STORE INCREMENTAL LENGTH OF PATH%INDEX% BASED ON NODES

	CMSEL,S,'START%INDEX(INC1,1)%',NODE										! SELECT START POINT ON PATH%INDEX%	
	*GET,ND1,NODE,,NUM,MIN													! NODE NUMBER OF THE START POINT ON PATH%INDEX%
	ALLSEL,ALL

	CMSEL,S,'PATH%INDEX(INC1,1)%',NODE										! SELECT THE NODES OF PATH%INDEX%

	PT_LEN%INDEX(INC1,1)%(1,1) = 0
	
	*DO,INC2,1,PT_ND%INDEX(INC1,1)%
		
		N_PT%INDEX(INC1,1)%(INC2,1) = ND1									
		X_PT%INDEX(INC1,1)%(INC2,1) = NX(ND1)
		Y_PT%INDEX(INC1,1)%(INC2,1) = NY(ND1)
		Z_PT%INDEX(INC1,1)%(INC2,1) = NZ(ND1)
		ND2 = NNEAR(ND1)

		*IF,INC2,NE,PT_ND%INDEX(INC1,1)%,THEN
			PT_LEN%INDEX(INC1,1)%(INC2+1,1) = PT_LEN%INDEX(INC1,1)%(INC2,1)+DISTND(ND1,ND2)
		*ENDIF

		NSEL,U,NODE,,ND1
		ND1 = ND2
	*ENDDO							! INC2

	ALLSEL,ALL
	TOT_LEN%INDEX(INC1,1)% = PT_LEN%INDEX(INC1,1)%(PT_ND%INDEX(INC1,1)%,1)	! TOTAL LENGTH OF THE PATH%INDEX%
	VEL_M%INDEX(INC1,1)% = VELOCITY(INC1,1)

*ENDDO								! INC1

!====================================================================================================
! AT THIS POINT, WE HAVE (X,Y,Z) OF EACH NODE OF EACH PATH, TOTAL LENGTH OF THE PATH, TOTAL NUMBER OF NODES IN EACH PATH
! SAMPLE ARRAY FOR FIRST PATH WILL BE:

! PT_ND1 = SCALAR CONTAINING NUMBER OF NODES IN PATH1
! N_PT1 = ARRAY CONTAINING NODE NUMBER OF PATH1
! X_PT1 = ARRAY CONTAINING X COORDINATES OF NODES ON PATH1
! Y_PT1 = ARRAY CONTAINING Y COORDINATES OF NODES ON PATH1 
! Z_PT1 = ARRAY CONTAINING Z COORDINATES OF NODES ON PATH1 
! PT_LEN1 = ARRAY TO STORE INCREMENTAL LENGTH OF PATH1 BASED ON NODES
! TOT_LEN1 = TOTAL LENGTH OF THE PATH1
!====================================================================================================
! DETERMINE ON/OFF TIME FOR EACH MOVING FLUX LOAD
!====================================================================================================

*VSCFUN,MAX_T,MAX,TMLT				! MAX END TIME AMONG ALL THE PATHS
*VSCFUN,MIN_T,MIN,TMST				! MIN END TIME AMONG ALL THE PATHS (IDEALLY IT SHOULD BE ZERO)

DT = MAX_T/LSTP(NLINE,1)				! TIME STEP SIZE DURING THE APPLICATION OF MOVING HEAT FLUX

*DIM,T_NR,ARRAY,SEG,1				! ARRAY WITH LINEAR RAMPING OF TIME
*DIM,P1,ARRAY,SEG,1
*VFILL,T_NR,RAMP,0,DT		

*DO,INC1,1,NLINE					! LOOP OVER EACH PATH
	
	TM_S = TMST(INC1,1)
	*VOPER,P1,T_NR,GE,TM_S
	*VSCFUN,TS%INDEX(INC1,1)%,FIRST,P1		! LOAD STEP AT WHICH MOVING FLUX%INDEX% WILL START
	
	TM_E = TMLT(INC1,1)
	*VOPER,P1,T_NR,GE,TM_E
	*VSCFUN,TE%INDEX(INC1,1)%,FIRST,P1		! LOAD STEP AT WHICH MOVING FLUX%INDEX% WILL END

*stat,TS%INDEX(INC1,1)%
*stat,TE%INDEX(INC1,1)%
	
*ENDDO		! INC1
	
!==============================================================
! STORE ALL NODE LOCATIONS IN AN ARRAY
!==============================================================
ALLSEL,ALL
*GET,NDT,NODE,,COUNT

*DIM,VARY_LD,ARRAY,NDT,1		!ARRAY TO STORE FLUX VALUE AT EACH TIME STEP

*DIM,X_LOC,ARRAY,NDT,1			!ARRAY TO STORE X LOCATION OF NODES
*DIM,Y_LOC,ARRAY,NDT,1			!ARRAY TO STORE Y LOCATION OF NODES
*DIM,Z_LOC,ARRAY,NDT,1			!ARRAY TO STORE Z LOCATION OF NODES

*VGET,X_LOC,NODE,,LOC,X
*VGET,Y_LOC,NODE,,LOC,Y
*VGET,Z_LOC,NODE,,LOC,Z

!=============================================================================
! CREATE MASK TO ZEROED OUT FLUX ON NODES WHICH DO NOT BELONG TO 'FACE%INDEX%'
!==============================================================================	

*DO,INC1,1,NLINE
	CMSEL,S,'FACE%INDEX(INC1,1)%',NODE				! SELECT SURFACE ON WHICH MOVING FLUX%INDEX% IS APPLIED
	*VGET,NMASK,NODE,,NSEL
	*VOPER,NMASK_1,NMASK,ADD,1
	*VOPER,NMASK%INDEX(INC1,1)%,NMASK_1,DIV,2		! MASK WILL BE USED TO ZEROED OUT FLUX ON NODES WHICH DO NOT BELONG TO 'FACE%INDEX%'
*ENDDO

!==============================================================
!============CREATE SURFACE ELEMENTS FROM THE FLUX LOAD========
!==============================================================
ALLSEL,ALL

*GET,MAX_TYP,ETYP,,NUM,MAX
*GET,MAX_MAT,MAT,,NUM,MAX
*GET,MAX_RL,RCON,,NUM,MAX

ET,MAX_TYP+1,152
KEYOPT,MAX_TYP+1,8,1	! HEAT FLUX OPTION (IGNORE CONVECTION)
TYPE,MAX_TYP+1
MAT,MAX_MAT+1
REAL,MAX_RL+1
CMSEL,S,FACE
ESURF
ALLSEL,ALL

!==============================================================
!============DELETE Killed_ele.txt and read_kill.txt===========
!==============================================================

/INQUIRE,EXT,EXIST,Killed_ele,TXT	
*IF,EXT,EQ,1,THEN
	/DELETE,Killed_ele,TXT
*ENDIF

/INQUIRE,EXT,EXIST,read_kill,TXT	
*IF,EXT,EQ,1,THEN
	/DELETE,read_kill,TXT
*ENDIF
!==============================================================
!============COMPUTE SURFACE LOAD AND SOLVE====================
!==============================================================
/SOLU

*DO,INC1,1,SEG								! LOOP OVER TIME STEPS

	*DO,INC2,1,NLINE						! LOOP OVER EACH MOVING FLUX LOAD

		*IF,INC1,GE,TS%INDEX(INC2,1)%,AND,INC1,LE,TE%INDEX(INC2,1)%,THEN
			
			
			! ===== FIND CENTERS FOR THE MOVING HEAT FLUX FOR EACH LASER======
			
			DIST_1%INDEX(INC2,1)% = INC1-TS%INDEX(INC2,1)%
			DIST_2%INDEX(INC2,1)% = DIST_1%INDEX(INC2,1)%*DT
			DIST%INDEX(INC2,1)%  = DIST_2%INDEX(INC2,1)%*VEL_M%INDEX(INC2,1)%						! DISTANCE TRAVELLED FROM START POINT OF THE MOVING FLUX%INDEX%
			
			*VOPER,LOC1%INDEX(INC2,1)%,PT_LEN%INDEX(INC2,1)%,GE,DIST%INDEX(INC2,1)%					
			*VSCFUN,LOC2%INDEX(INC2,1)%,FIRST,LOC1%INDEX(INC2,1)%
			LOC3%INDEX(INC2,1)% = LOC2%INDEX(INC2,1)%-1
			A0 = PT_ND%INDEX(INC2,1)%
	
			*IF,INC1,EQ,TS%INDEX(INC2,1)%,THEN
				A = X_PT%INDEX(INC2,1)%(1,1)
				B = Y_PT%INDEX(INC2,1)%(1,1)
				C = Z_PT%INDEX(INC2,1)%(1,1)
				
			*ELSEIF,INC1,EQ,TE%INDEX(INC2,1)%,THEN	
				A = X_PT%INDEX(INC2,1)%(A0,1)
				B = Y_PT%INDEX(INC2,1)%(A0,1)
				C = Z_PT%INDEX(INC2,1)%(A0,1)								
			*ELSE	
				RT = (DIST%INDEX(INC2,1)%-PT_LEN%INDEX(INC2,1)%(LOC3%INDEX(INC2,1)%,1))/(PT_LEN%INDEX(INC2,1)%(LOC2%INDEX(INC2,1)%,1)-PT_LEN%INDEX(INC2,1)%(LOC3%INDEX(INC2,1)%,1))			
				A = X_PT%INDEX(INC2,1)%(LOC3%INDEX(INC2,1)%,1) + RT*(X_PT%INDEX(INC2,1)%(LOC2%INDEX(INC2,1)%,1)-X_PT%INDEX(INC2,1)%(LOC3%INDEX(INC2,1)%,1))
				B = Y_PT%INDEX(INC2,1)%(LOC3%INDEX(INC2,1)%,1) + RT*(Y_PT%INDEX(INC2,1)%(LOC2%INDEX(INC2,1)%,1)-Y_PT%INDEX(INC2,1)%(LOC3%INDEX(INC2,1)%,1))
				C = Z_PT%INDEX(INC2,1)%(LOC3%INDEX(INC2,1)%,1) + RT*(Z_PT%INDEX(INC2,1)%(LOC2%INDEX(INC2,1)%,1)-Z_PT%INDEX(INC2,1)%(LOC3%INDEX(INC2,1)%,1))	
			
			*ENDIF
					
			! ====================================================================
			! CALCULATE THE HEAT FLUX CONTRIBUTION DUE TO EACH MOVING FLUX LOAD
			! ====================================================================
			*VOPER,A1,X_LOC,SUB,A								! (X-XO)
			*VOPER,B1,Y_LOC,SUB,B								! (Y-YO)
			*VOPER,C1,Z_LOC,SUB,C								! (Z-Z0)

			*VOPER,A2,A1,MULT,A1									! (X-XO)^2
			*VOPER,B2,B1,MULT,B1									! (Y-YO)^2
			*VOPER,C2,C1,MULT,C1									! (Z-ZO)^2

			*VOPER,A3,A2,ADD,B2									! (X-XO)^2 + (Y-YO)^2
			*VOPER,B3,A3,ADD,C2									! (X-XO)^2 + (Y-YO)^2 + (Z-ZO)^2
			
			R2 = -1*R1(INC2,1)*R1(INC2,1)
			*VOPER,A4,B3,DIV,R2									! -{(X-XO)^2 + (Y-YO)^2 + (Z-ZO)^2}/R^2
			*VFUN,B4,EXP,A4									! EXP[-{(X-XO)^2 + (Y-YO)^2 + (Z-ZO)^2}/R^2]
			
			AA1 = LD(INC2,1)
			*VOPER,L_D1,AA1,MULT,B4								! LD*EXP[-{(X-XO)^2 + (Y-YO)^2 + (Z-ZO)^2}/R^2]
			*VOPER,VARY_LD1,L_D1,MULT,NMASK%INDEX(INC2,1)%					! PUT ZERO FLUX TO ANY NODE WHICH DO NOT BELONG TO 'FACE"
			
			*VOPER,VARY_LD,VARY_LD,ADD,VARY_LD1
		*ENDIF								
			
	*ENDDO													! INC2

			SFFUN,HFLUX,VARY_LD(1)								! APPLYING DISTRIBUTED LOAD ON THE WHOLE SURFACE
			ESEL,S,TYPE,,MAX_TYP+1
			SFE,ALL,1,HFLUX,1,0		

	TM = DT*INC1
	
	TIME,TM
	NSUB,1
	ALLSEL,ALL

	SOLVE
*DIM,VARY_LD,ARRAY,NDT,1

*ENDDO	

*DIM,VARY_LD,ARRAY,NDT,1
ESEL,S,TYPE,,MAX_TYP+1
NSLE
SFEDELE,ALL,ALL,HFLUX
ALLSEL,ALL


/COM, END OF MOVING HEAT FLUX
AUTOTS,ON
NSUB,20,100000000,20
TIMINT,ON
TIME,200.0

! ****** End   Command Snippet ******
! *********** WB SOLVE COMMAND ***********
! check interactive state
*get,ANSINTER_,active,,int
*if,ANSINTER_,ne,0,then
/eof
*endif
solve
/com *************** Write FE CONNECTORS ********* 
CEWRITE,file,ce,,INTE
/com,****************************************************
/com,*************** FINISHED SOLVE FOR LS 1 *************
*get,_wallasol,active,,time,wall
/post1
xmlo,ENCODING,ISO-8859-1
xmlo,parm
/xml,parm,xml
fini
/gopr
*get,_walldone,active,,time,wall
_preptime=(_wallbsol-_wallstrt)*3600
_solvtime=(_wallasol-_wallbsol)*3600
_posttime=(_walldone-_wallasol)*3600
_totaltim=(_walldone-_wallstrt)*3600
*get,_dlbratio,active,0,solu,dlbr
*get,_combtime,active,0,solu,comb
*get,_ssmode,active,0,solu,ssmm
*get,_ndofs,active,0,solu,ndof
/fclean				!clean distributed files
/com,--- Total number of nodes = %_numnode%
/com,--- Total number of elements = %_numelem%
/com,--- Element load balance ratio = %_dlbratio%
/com,--- Time to combine distributed files = %_combtime%
/com,--- Sparse memory mode = %_ssmode%
/com,--- Number of DOF = %_ndofs%
/wb,file,end               ! done with WB generated input
